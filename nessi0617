local function DrawESP()
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local char = p.Character
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            
            -- 名前 ESP (BillboardGui)
            if _G.NessiConfig.NameESP then
                if not char:FindFirstChild("NessiESP") then
                    local gui = Instance.new("BillboardGui", char)
                    gui.Name = "NessiESP"; gui.AlwaysOnTop = true; gui.Size = UDim2.new(0, 100, 0, 40); gui.StudsOffset = Vector3.new(0, 3, 0)
                    local txt = Instance.new("TextLabel", gui)
                    txt.Size = UDim2.new(1, 0, 1, 0); txt.BackgroundTransparency = 1; txt.TextColor3 = Theme.Accent; txt.Font = Enum.Font.GothamBold; txt.TextSize = 12
                    task.spawn(function()
                        while char:FindFirstChild("NessiESP") and _G.NessiConfig.NameESP do
                            txt.Text = p.DisplayName .. "\n[" .. math.floor(hum.Health) .. " HP]"
                            task.wait(0.2)
                        end
                        gui:Destroy()
                    end)
                end
            end
            
            -- ボックス ESP
            if _G.NessiConfig.BoxESP then
                if not root:FindFirstChild("NessiBox") then
                    local box = Instance.new("BoxHandleAdornment", root)
                    box.Name = "NessiBox"; box.AlwaysOnTop = true; box.ZIndex = 5; box.Transparency = 0.6; box.Adornee = root; box.Size = Vector3.new(4, 6, 4); box.Color3 = Theme.Accent
                end
            elseif root:FindFirstChild("NessiBox") then root.NessiBox:Destroy() end
        end
    end
end
RunService.RenderStepped:Connect(function() pcall(DrawESP) end)

