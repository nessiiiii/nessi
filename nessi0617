-- --- 【7. 核心：Aimbot Hook (通信の書き換えロジック) 】 ---
-- 1行も省略せず、通信をフックして攻撃を必中に変えるぜ。
local function InitNessiAimbot()
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        if _G.NessiConfig.MapAttack and tostring(method) == "FireServer" then
            if tostring(self) == "RemoteEvent" or tostring(self) == "LeftClickRemote" then
                -- 周囲の敵NPCを優先的にターゲット
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        args[2] = v.HumanoidRootPart.Position
                        return oldNamecall(self, unpack(args))
                    end
                end
                -- NPCがいなければターゲットプレイヤーを優先
                if _G.NessiConfig.TargetPlayer and _G.NessiConfig.TargetPlayer.Character then
                    local tRoot = _G.NessiConfig.TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if tRoot then
                        args[2] = tRoot.Position
                        return oldNamecall(self, unpack(args))
                    end
                end
            end
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end
pcall(InitNessiAimbot)

-- --- 【8. 核心：メイン戦闘 ＆ 海王狩り ＆ 物理ループ】 ---
task.spawn(function()
    local RS_Net = RS:WaitForChild("Modules"):WaitForChild("Net")
    local RegAttack = RS_Net:WaitForChild("RE/RegisterAttack")
    local RegHit = RS_Net:WaitForChild("RE/RegisterHit")

    while task.wait() do
        pcall(function()
            local char = LP.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local hum = char:FindFirstChild("Humanoid")
            local tool = char:FindFirstChildOfClass("Tool")

            -- [ 爆速・足加速 (Speed Hack) ]
            if _G.NessiConfig.SpeedHack and hum and hum.MoveDirection.Magnitude > 0 then
                char:TranslateBy(hum.MoveDirection * _G.NessiConfig.StepSpeed)
            end

            -- [ シービースト狩り (SB Farm) ]
            if _G.NessiConfig.SBFarm then
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if string.find(string.lower(v.Name), "sea beast") or string.find(string.lower(v.Name), "seabeast") then
                        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                            -- 被弾回避のため上空 80スタッドに固定
                            char.HumanoidRootPart.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 80, 0)
                            -- 攻撃信号
                            local hitList = {{v, v.HumanoidRootPart}}
                            RegAttack:FireServer(0.01)
                            RegHit:FireServer(v.HumanoidRootPart, hitList)
                            if tool and tool:FindFirstChild("LeftClickRemote") then
                                tool.LeftClickRemote:FireServer(v.HumanoidRootPart.Position, 1)
                            end
                            break
                        end
                    end
                end
            end

            -- [ 極限ファストアタック ＆ 全マップ攻撃 ]
            if (_G.NessiConfig.FastAttack or _G.NessiConfig.MapAttack) and not _G.NessiConfig.SBFarm then
                local hitList = {}
                -- NPC スキャン
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                        table.insert(hitList, {v, v.HumanoidRootPart})
                    end
                end
