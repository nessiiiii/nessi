    -- 視覚更新ロジック
    local function UpdateToggleVisuals()
        local active = _G.NessiConfig[configKey]
        TS:Create(statusBase, TweenInfo.new(0.2), {BackgroundColor3 = active and Theme.Accent or Theme.MainBG}):Play()
