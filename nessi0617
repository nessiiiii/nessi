                        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                            -- 海王の上空へTP＆固定
                            hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 80, 0)
                            local hitList = {{v, v.HumanoidRootPart}}
                            RegAttack:FireServer(0.01)
                            RegHit:FireServer(v.HumanoidRootPart, hitList)
                            break
                        end
                    end
                end
            end

            -- [ 必中ファストアタック (対人・対NPCハイブリッド) ]
            if _G.NessiConfig.FastAttack or _G.NessiConfig.MapAttack then
                local hitList = {}
                
                -- NPCをヒットリストへ追加
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                        table.insert(hitList, {v, v.HumanoidRootPart})
                        if _G.NessiConfig.InstantKill then v.Humanoid.Health = 0 end
                    end
                end

                -- プレイヤーをヒットリストへ追加 (ここが必中の鍵だぶろ！)
                for _, p in pairs(game:GetService("Players"):GetPlayers()) do
                    if p ~= LP and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                        local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
                        if pRoot then table.insert(hitList, {p.Character, pRoot}) end
                    end
                end

                -- まとめてヒット信号送信
                if #hitList > 0 then
                    RegAttack:FireServer(0.01)
                    RegHit:FireServer(hitList[1][2], hitList)
                    if tool and tool:FindFirstChild("LeftClickRemote") then
                        -- 指定したLookPart（Headなど）の座標を狙う
                        local lookPos = hitList[1][2].Position
                        if _G.NessiConfig.LookPart == "Head" and hitList[1][1]:FindFirstChild("Head") then
                            lookPos = hitList[1][1].Head.Position
                        end
                        tool.LeftClickRemote:FireServer(lookPos, 1)
                    end
                end
            end
        end)
    end
end)

